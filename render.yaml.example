# render.yaml.example
#
# Referencia actual para configurar los servicios base de RUTA en Render.
# Los secretos deben configurarse en Render Dashboard o env groups.

services:
  - type: web
    name: ruta-api
    runtime: node
    repo: https://github.com/orkoruta/backend-ruta
    rootDir: .
    buildCommand: >-
      npm install pnpm@11.4.0 --no-save &&
      node_modules/.bin/pnpm install --frozen-lockfile &&
      node_modules/.bin/pnpm --filter @ruta/api build
    startCommand: pnpm --filter @ruta/api start
    healthCheckPath: /healthz
    plan: starter
    envVars:
      - key: NODE_ENV
        value: production
      - key: PORT
        value: "3001"
      - key: HOST
        value: "0.0.0.0"
      - key: DATABASE_URL
        sync: false
      - key: JWT_SECRET
        sync: false
      - key: JWT_ACCESS_TOKEN_LIFETIME_MINUTES
        value: "15"
      - key: JWT_REFRESH_TOKEN_LIFETIME_DAYS
        value: "7"
      - key: WOMPI_PUBLIC_KEY
        sync: false
      - key: WOMPI_PRIVATE_KEY
        sync: false
      - key: WOMPI_WEBHOOK_SECRET
        sync: false
      - key: CORS_ORIGINS
        sync: false
      - key: LOGTAIL_TOKEN
        sync: false
      - key: NPM_TOKEN
        sync: false

  - type: worker
    name: ruta-api-worker
    runtime: node
    repo: https://github.com/orkoruta/backend-ruta
    rootDir: .
    buildCommand: >-
      npm install pnpm@11.4.0 --no-save &&
      node_modules/.bin/pnpm install --frozen-lockfile &&
      node_modules/.bin/pnpm --filter @ruta/api build
    startCommand: pnpm --filter @ruta/api start:worker
    plan: starter
    envVars:
      - key: NODE_ENV
        value: production
      - key: DATABASE_URL
        sync: false
      - key: JWT_SECRET
        sync: false
      - key: NPM_TOKEN
        sync: false

  - type: web
    name: ruta-admin
    runtime: static
    repo: https://github.com/orkoruta/frontend-ruta
    rootDir: .
    buildCommand: >-
      npm install pnpm@11.3.0 --prefix=/tmp/pnpm-bin --no-save &&
      /tmp/pnpm-bin/node_modules/.bin/pnpm install --frozen-lockfile &&
      /tmp/pnpm-bin/node_modules/.bin/pnpm --filter @ruta/admin build
    staticPublishPath: ./admin/out
    envVars:
      - key: NEXT_PUBLIC_API_URL
        value: https://ruta-api.onrender.com
      - key: NPM_TOKEN
        sync: false

  - type: web
    name: ruta-storefront
    runtime: static
    repo: https://github.com/orkoruta/frontend-ruta
    rootDir: .
    buildCommand: >-
      npm install pnpm@11.3.0 --prefix=/tmp/pnpm-bin --no-save &&
      /tmp/pnpm-bin/node_modules/.bin/pnpm install --frozen-lockfile &&
      /tmp/pnpm-bin/node_modules/.bin/pnpm --filter @ruta/storefront build
    staticPublishPath: ./storefront/out
    envVars:
      - key: NEXT_PUBLIC_API_URL
        value: https://ruta-api.onrender.com
      - key: NPM_TOKEN
        sync: false
